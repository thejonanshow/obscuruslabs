# --- App mode ------------------------------------------------------
# coming_soon | full
SITE_MODE=full
NOINDEX=true
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Staging basic auth --------------------------------------------
# Set both to enable. Leave empty in production.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Stripe ---------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (transactional email) ----------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM="obscurus labs <hello@obscuruslabs.com>"

# --- Plausible ------------------------------------------------------
# Get this URL from your Plausible dashboard (Settings → Script URL).
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/pa-XXXXXXXX.js

# --- Sentry ---------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENV=development
