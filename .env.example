# --- App mode ------------------------------------------------------
# coming_soon | full
SITE_MODE=full
NOINDEX=true
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Staging basic auth --------------------------------------------
# Set both to enable. Leave empty in production.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=

# --- Stripe ---------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Resend (transactional email) ----------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM="obscurus labs <hello@obscuruslabs.com>"
# Audience that /api/waitlist/confirm writes contacts into. Create via:
#   curl -X POST https://api.resend.com/audiences -H "Authorization: Bearer $RESEND_API_KEY" -d '{"name":"VISO .01 Waitlist"}'
RESEND_AUDIENCE_ID=

# --- Waitlist double opt-in ----------------------------------------
# HMAC secret used to sign the confirmation links emailed to subscribers.
# Generate with: openssl rand -base64 32
# Different value per environment. Required at runtime.
WAITLIST_TOKEN_SECRET=

# --- Prototype sales (maintenance-page CTA) ------------------------
# Hard cap on the prototype run. Inventory is counted from completed
# Stripe Checkout sessions with metadata.sku === 'viso-prototype'.
PROTOTYPE_LIMIT=12
# Kill switch — set to 'false' to pause prototype sales without
# changing the cap.
PROTOTYPE_AVAILABLE=true

# --- Plausible ------------------------------------------------------
# Get this URL from your Plausible dashboard (Settings → Script URL).
NEXT_PUBLIC_PLAUSIBLE_SCRIPT_SRC=https://plausible.io/js/pa-XXXXXXXX.js

# --- Sentry ---------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ENV=development
